# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (local only — .env.example is committed)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client (output path configured in prisma/schema.prisma)
/lib/db/generated/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Local storage adapter writes here in development
/storage-uploads/
