// Prisma schema for the V1 internship job board.
// Connection URL is loaded from .env via prisma.config.ts.

generator client {
  provider = "prisma-client"
  output   = "../lib/db/generated"
}

datasource db {
  provider = "postgresql"
}

// -------- Enums --------

enum UserRole {
  STUDENT
  COMPANY
  ADMIN
}

enum CompanyApprovalStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum JobPostingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  IN_REVIEW
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

enum WorkplaceType {
  REMOTE
  HYBRID
  ONSITE
}

enum CompensationType {
  PAID
  UNPAID
  STIPEND
}

enum InternshipTerm {
  SUMMER
  FALL
  WINTER
  SPRING
  YEAR_ROUND
}

enum ActivityEventType {
  STUDENT_SIGNUP
  COMPANY_SIGNUP
  COMPANY_APPROVAL_CHANGED
  JOB_POSTING_PUBLISHED
  APPLICATION_SUBMITTED
  APPLICATION_STATUS_CHANGED
  MESSAGE_THREAD_CREATED
}

// -------- Models --------

/// Application user. `email` uniqueness is soft-delete-safe via the partial
/// unique index `User_email_active_key` (see migration). When a row is soft
/// deleted, `deletedAt` is set so the partial index no longer constrains it,
/// permitting re-registration with the same email.
model User {
  id           String    @id @default(cuid())
  email        String
  passwordHash String?
  role         UserRole
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  studentProfile StudentProfile?
  companyProfile CompanyProfile?

  initiatedThreads MessageThread[] @relation("ThreadInitiator")
  sentMessages     Message[]       @relation("MessageSender")
  activityEvents   ActivityEvent[] @relation("ActivityActor")
  adminNotes       AdminNote[]     @relation("AdminNoteAuthor")

  @@index([role])
  @@index([deletedAt])
}

model StudentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  fullName          String
  headline          String?
  university        String?
  graduationYear    Int?
  degree            String?
  major             String?
  location          String?
  workAuthorization String?
  bio               String?
  resumeStorageKey  String?
  portfolioUrl      String?
  linkedinUrl       String?
  githubUrl         String?
  programTag        String?
  isProfileComplete Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       StudentSkill[]
  experiences  StudentExperience[]
  projects     StudentProject[]
  applications Application[]
  savedJobs    SavedJobPosting[]

  @@index([programTag])
  @@index([isProfileComplete])
}

model StudentSkill {
  id               String @id @default(cuid())
  studentProfileId String
  name             String

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, name])
  @@index([studentProfileId])
}

model StudentExperience {
  id               String    @id @default(cuid())
  studentProfileId String
  title            String
  organization     String
  startDate        DateTime?
  endDate          DateTime?
  description      String?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
}

model StudentProject {
  id               String  @id @default(cuid())
  studentProfileId String
  name             String
  url              String?
  description      String?

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
}

/// Company profile. `slug` uniqueness is soft-delete-safe via the partial
/// unique index `CompanyProfile_slug_active_key`.
model CompanyProfile {
  id               String                @id @default(cuid())
  userId           String                @unique
  companyName      String
  slug             String
  logoStorageKey   String?
  websiteUrl       String?
  industry         String?
  companySize      String?
  headquarters     String?
  shortDescription String?
  description      String?
  contactEmail     String?
  programTag       String?
  approvalStatus   CompanyApprovalStatus @default(PENDING)
  deletedAt        DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostings JobPosting[]

  @@index([approvalStatus])
  @@index([programTag])
  @@index([deletedAt])
}

/// Job posting. `slug` uniqueness within a company is soft-delete-safe via
/// the partial unique index `JobPosting_companyProfileId_slug_active_key`.
model JobPosting {
  id                  String            @id @default(cuid())
  companyProfileId    String
  slug                String
  title               String
  department          String?
  location            String?
  workplaceType       WorkplaceType
  internshipTerm      InternshipTerm?
  startDate           DateTime?
  duration            String?
  compensationType    CompensationType?
  compensationMin     Int?
  compensationMax     Int?
  description         String
  responsibilities    String?
  qualifications      String?
  applicationDeadline DateTime?
  status              JobPostingStatus  @default(DRAFT)
  programTag          String?
  publishedAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  companyProfile CompanyProfile    @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  applications   Application[]
  savedBy        SavedJobPosting[]

  @@index([companyProfileId])
  @@index([status])
  @@index([programTag])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([workplaceType])
  @@index([internshipTerm])
}

model SavedJobPosting {
  id               String   @id @default(cuid())
  studentProfileId String
  jobPostingId     String
  createdAt        DateTime @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  jobPosting     JobPosting     @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, jobPostingId])
  @@index([studentProfileId])
  @@index([jobPostingId])
}

model Application {
  id                       String            @id @default(cuid())
  jobPostingId             String
  studentProfileId         String
  coverLetter              String?
  resumeStorageKeySnapshot String?
  status                   ApplicationStatus @default(APPLIED)
  appliedAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  jobPosting     JobPosting      @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile  @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  threads        MessageThread[]

  @@unique([jobPostingId, studentProfileId])
  @@index([jobPostingId])
  @@index([studentProfileId])
  @@index([status])
  @@index([appliedAt])
}

model MessageThread {
  id                String   @id @default(cuid())
  applicationId     String
  initiatedByUserId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  initiatedByUser User        @relation("ThreadInitiator", fields: [initiatedByUserId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@index([applicationId])
  @@index([initiatedByUserId])
}

model Message {
  id           String    @id @default(cuid())
  threadId     String
  senderUserId String
  body         String
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUser User          @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderUserId])
  @@index([createdAt])
}

model ActivityEvent {
  id           String            @id @default(cuid())
  type         ActivityEventType
  actorUserId  String?
  entityType   String?
  entityId     String?
  metadataJson Json?
  createdAt    DateTime          @default(now())

  actorUser User? @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model AdminNote {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  authorUserId String
  body         String
  createdAt    DateTime @default(now())

  authorUser User @relation("AdminNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([authorUserId])
}
