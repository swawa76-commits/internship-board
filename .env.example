# Copy this file to `.env` and fill in real values for local development.
# `.env` is git-ignored. Never commit real secrets.

# PostgreSQL connection string used by Prisma.
# Local example (running Postgres on default port):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/internship_dev?schema=public"

# Auth.js / NextAuth secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me-with-a-strong-random-string"
