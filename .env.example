# Copy this file to `.env` and fill in real values for local development.
# `.env` is git-ignored. Never commit real secrets.

# ─── Required (local dev + production) ──────────────────────────────────

# PostgreSQL connection string used by Prisma. The app uses
# `@prisma/adapter-pg` (driver adapter), so any libpq-compatible URL
# works. Local example (running Postgres on the default port):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/internship_dev?schema=public"

# Auth.js (formerly NextAuth) JWT signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required in BOTH dev and production. Use a different value per
# environment.
AUTH_SECRET="replace-me-with-a-strong-random-string"

# ─── Optional (Next.js standard) ────────────────────────────────────────

# Override the auth callback origin if the app is reached at a hostname
# other than the one Next.js infers (e.g., behind a proxy). Usually only
# needed in production. Auth.js v5 will warn if this is unset and the
# environment is production.
# AUTH_URL="https://your-app.example.com"

# Standard Node mode flag. Next.js sets this for you in `next dev` and
# `next start`; only override if you have a specific reason. Several
# behaviors gate on `NODE_ENV === "production"` (see STORAGE_DRIVER).
# NODE_ENV="development"

# ─── Storage adapter (server/adapters/storage) ──────────────────────────

# Selects which storage backend handles resume + logo uploads.
#   local | local-fs   → LocalFsStorageAdapter (writes to ./storage-uploads)
#   noop               → NoopStorageAdapter (in-memory; tests only)
#   s3                 → S3StorageAdapter (production)
#
# When unset, defaults to local-fs. An UNKNOWN value falls back to
# local-fs in development with a console warning, but FAILS LOUDLY ON
# BOOT in production (NODE_ENV=production) — by design.
STORAGE_DRIVER="local"

# ─── S3 storage (production only) ───────────────────────────────────────
#
# Required IFF STORAGE_DRIVER=s3. Construction validates every required
# key up-front and throws a clear error if any are missing. The adapter
# uses @aws-sdk/client-s3, so any S3-compatible backend works (AWS S3,
# Cloudflare R2, MinIO, etc.).
#
# S3_BUCKET="internshipboard-uploads"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="AKIA..."
# S3_SECRET_ACCESS_KEY="..."
#
# Optional: signed-URL TTL in seconds for presigned GET reads.
# Defaults to 300 (5 minutes) inside the adapter.
# S3_SIGNED_URL_TTL_SECONDS="300"
#
# Optional: custom S3-compatible endpoint. Required for Cloudflare R2;
# leave unset for AWS S3 to use the default regional endpoint.
# For Cloudflare R2:
#   S3_REGION="auto"
#   S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# S3_ENDPOINT=""
#
# Optional: force path-style URLs (bucket in the path, not the host).
# Defaults to false. R2's virtual-hosted style works fine for the SDK,
# so most R2 deployments can leave this unset. Set to "true" only if
# your provider requires path-style addressing (e.g. older MinIO).
# S3_FORCE_PATH_STYLE="false"

# ─── Email adapter (server/adapters/email) ──────────────────────────────

# Selects which email transport sends notifications (welcome,
# application status changes, new messages, admin pending review, etc.).
#   console            → ConsoleEmailAdapter (logs to stdout)
#   resend             → ResendEmailAdapter (production)
#   (any other value)  → falls back to console with a warning
#
# When unset, defaults to console. Even with a real provider configured,
# dispatch failures NEVER roll back the primary database mutation —
# every send is wrapped in `dispatchEmail`'s safe-fire wrapper.
EMAIL_DRIVER="console"

# ─── Resend (production only) ───────────────────────────────────────────
#
# Required IFF EMAIL_DRIVER=resend. Construction validates every required
# key up-front and throws a clear error if any are missing.
#
# RESEND_API_KEY="re_..."
# Sender. Use a verified domain. Either a bare address or RFC-2822
# "Display Name <addr@domain>". Examples:
#   EMAIL_FROM="alerts@yourdomain.com"
#   EMAIL_FROM="InternshipBoard <alerts@yourdomain.com>"
# EMAIL_FROM=""
#
# Optional. Single Reply-To address applied to every outbound message.
# EMAIL_REPLY_TO="support@yourdomain.com"

# ─── Playwright (tests only, optional) ──────────────────────────────────
# Override the URL Playwright targets. Defaults to http://localhost:${PORT}
# (PORT also defaults to 3000). Only set this if you're running the dev
# server somewhere unusual.
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
